[flake8]
max-line-length = 88
extend-ignore = E203, E501
exclude =
    .git,
    __pycache__,
    build,
    dist,
    *.egg-info,
    venv,
    env
per-file-ignores =
    __init__.py:F401
# F401 is "imported but unused" - often legitimate in __init__.py files

# Settings for flake8-docstrings
docstring-convention = google
