[MASTER]
# 1. Base Name Ignore: Skips folders named exactly like this during recursive crawling
ignore=CVS,.git,venv,env,.venv,alembic,setup.py,build

# 2. Strict Path Regex Ignore: Blocks the root environment, src environment, and build environment completely
ignore-paths=^\.venv/.*,^src/py_lib/\.venv/.*,^build/\.venv/.*,^build/.*

# Automatically injects your library path for pre-commit, build.sh, and IDE extensions
init-hook="import sys; sys.path.insert(0, 'src/py_lib')"

[FORMAT]
max-line-length=110

[MESSAGES CONTROL]
disable=
    C0111,  # Missing docstring (handled by flake8-docstrings)
    W0511,  # TODO/FIXME messages
    W0718,  # Exception is too general
    R0903,  # Too few public methods
    C0103,  # Invalid name
    R0913,  # Too many arguments
    R0914   # Too many local variables

[REPORTS]
output-format=colorized
reports=no
score=no

[SIMILARITIES]
min-similarity-lines=4
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=yes

[BASIC]
good-names=i,j,k,ex,Run,_,id,df

[VARIABLES]
init-import=no
